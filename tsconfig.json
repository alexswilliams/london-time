{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "isolatedModules": true, // esbuild required isolatedModules=true
    "declaration": true, // to emit the .d.ts files in /dist/
    "declarationMap": true, // to allow navigation back to the source
  }
}
