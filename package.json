{
  "name": "london-time",
  "version": "0.0.1",
  "description": "Parser and formatter for switching between London and UTC dates, times and instants",
  "main": "src/london-time.ts",
  "scripts": {
    "src:build": "tsc --project tsconfig.json",
    "src:minify": "esbuild src/london-time.ts --minify --format=cjs --outfile=dist/london-time.min.js --target=chrome90,edge91,firefox89,ios14.0,safari14,node18 --analyze",
    "src:test": "vitest run src/**.test.*",
    "test": "npm run src:test"
  },
  "workspaces": [
    "src",
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "esbuild": "0.28.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
